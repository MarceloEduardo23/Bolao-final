# ===================================================
# Copa Palpite 2026 — Variáveis de Ambiente
# ===================================================
# Copie este arquivo para .env.local e preencha os valores

# ----- Banco de Dados (Neon PostgreSQL) -----
# Crie em: https://neon.tech → New Project → copie a "Connection string"
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ----- JWT -----
# Gere um segredo forte: openssl rand -base64 32
JWT_SECRET="troque-por-um-segredo-forte-de-pelo-menos-32-chars"

# ----- OAuth Google (opcional) -----
# Crie em: https://console.cloud.google.com → Credenciais → ID do cliente OAuth 2.0
# URI de redirecionamento autorizado: http://localhost:3000/api/auth/callback/google
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ----- Ambiente -----
NODE_ENV="development"
